# nite-eval environment configuration
# Copy this file to `.env` and edit values for your machine.
# `scripts/run_nightly.sh` sources `.env` automatically if present.

# --- Binaries ---
# Path to llama.cpp's llama-server binary
LLAMA_SERVER_BIN=/path/to/llama.cpp/build/bin/llama-server
# Path to llama-swap binary (https://github.com/mostlygeek/llama-swap)
LLAMA_SWAP_BIN=/path/to/llama-swap/llama-swap

# --- Model files ---
# Directory containing target GGUF models (Qwen, Gemma, etc.)
GGUF_DIR=/path/to/gguf/models
# Directory containing judge GGUF models
JUDGE_MODEL_DIR=/path/to/judge/models

REWARD_MODEL_FILE=RewardAnything-8B-v1.Q6_K.gguf
FLOW_MODEL_FILE=Flow-Judge-v0.1.Q6_K.gguf

# --- GPUs ---
# Use UUIDs (`nvidia-smi -L`) for stable pinning across reboots, or device indices.
TARGET_GPU=1
JUDGE_GPU=2
# Optional: pin via UUID inside llama-swap cmd (more reliable than indices)
TARGET_GPU_UUID=
JUDGE_GPU_UUID=

# --- Ports ---
TARGET_PORT=9070
REWARD_PORT=9091
FLOW_PORT=9092
